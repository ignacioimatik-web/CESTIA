# =============================================================================
# CESTA INTELIGENTE — Variables de Entorno
# =============================================================================
# Copia este archivo como .env.local y completa los valores.
#
# Supabase Project: https://supabase.com/dashboard/project/<tu-project-id>
#   - Project Settings → API → Project URL        → NEXT_PUBLIC_SUPABASE_URL
#   - Project Settings → API → anon public key     → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   - Project Settings → API → service_role secret → SUPABASE_SERVICE_ROLE_KEY

# -- Supabase -----------------------------------------------------------------
# URL del proyecto (ej: https://abcdefghijk.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clave anónima (pública, segura para el frontend)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave service_role (SOLO backend/admin, NUNCA exponer al frontend)
SUPABASE_SERVICE_ROLE_KEY=

# -- App ----------------------------------------------------------------------
# URL base de la aplicación (cambiar en producción)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Nombre de la aplicación
NEXT_PUBLIC_APP_NAME=Cesta Inteligente

# -- Mercadona Sync -----------------------------------------------------------
# Habilita el sincronizador experimental del catálogo de Mercadona.
# Solo actívalo si aceptas los términos de uso de Mercadona.
MERCADONA_SYNC_ENABLED=false

# Secreto compartido para invocar la Edge Function de sync
# (genera uno con: openssl rand -hex 32)
SYNC_SECRET=

# -- AI ------------------------------------------------------------------------
# API key de OpenAI para generación de recetas con IA
# Obtén una en: https://platform.openai.com/api-keys
OPENAI_API_KEY=
